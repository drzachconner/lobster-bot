{
  "permissions": {
    "allow": [
      "Read",
      "WebSearch",
      "WebFetch(*)",
      "Write(./memory/**)",
      "Edit(./memory/**)",
      "Bash(date*)",
      "Bash(python3*)",
      "Bash(curl -s*)",
      "Bash(ls*)",
      "Bash(cat*)",
      "Bash(head*)",
      "Bash(tail*)",
      "Bash(wc*)",
